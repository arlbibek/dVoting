n    <h1>This is Results Page</h1>\r\n\r\n    <div className='winner-container'>\r\n      <div className='winner-info'>\r\n      <p className='winner-tag'>Winner!</p>\r\n      <h2>{winner.header}</h2>\r\n      <p className='winner-slogan'>{winner.slogan}</p>\r\n      </div>\r\n      <div className='winner-votes'>\r\n        <div className='votes-tag'>Votes: </div>\r\n        <div className='vote-count'>{winner.votes}</div>\r\n      </div>\r\n    </div>\r\n\r\n    <div className='results-container'>\r\n      <p>Total Votes casted: {calcTotalVotes(result)}</p>\r\n      <table>\r\n        <thead>\r\n          <tr>\r\n            <th>Candidates</th>\r\n            <th>Total Votes</th>\r\n          </tr>\r\n        </thead>\r\n        <tbody>\r\n          {result.map(renderResults)}\r\n        </tbody>\r\n    </table>\r\n    </div>\r\n    <br />\r\n    <br />\r\n    </>\r\n  )\r\n}\r\n\r\nexport default Results;\r\n","C:\\Users\\bibek\\Google Drive\\College Files\\3 r d Y e a r\\F Y P\\FYP - DEV\\dVoting\\front-end dVoting\\src\\pages\\home\\Home.js",[],"C:\\Users\\bibek\\Google Drive\\College Files\\3 r d Y e a r\\F Y P\\FYP - DEV\\dVoting\\front-end dVoting\\src\\pages\\home\\voters\\VotersTable.js",[],"C:\\Users\\bibek\\Google Drive\\College Files\\3 r d Y e a r\\F Y P\\FYP - DEV\\dVoting\\front-end dVoting\\src\\pages\\home\\voters\\columns.js",[],{"ruleId":"53","replacedBy":"54"},{"ruleId":"55","replacedBy":"56"},{"ruleId":"57","severity":1,"message":"58","line":1,"column":17,"nodeType":"59","messageId":"60","endLine":1,"endColumn":26},{"ruleId":"61","severity":1,"message":"62","line":9,"column":11,"nodeType":"63","messageId":"64","endLine":9,"endColumn":13},{"ruleId":"57","severity":1,"message":"65","line":7,"column":9,"nodeType":"59","messageId":"60","endLine":7,"endColumn":18},"no-native-reassign",["66"],"no-negated-in-lhs",["67"],"no-unused-vars","'Component' is defined but never used.","Identifier","unusedVar","eqeqeq","Expected '===' and instead saw '=='.","Bi